# LiteLLM model (provider/model format)
LITELLM_MODEL=openai/gpt-4o
LITELLM_TEMPERATURE=0.1

# Provider API keys — set the one matching your model
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Browser options
BROWSER_HEADLESS=false
BROWSER_TIMEOUT_MS=30000
BROWSER_NAVIGATION_TIMEOUT_MS=30000
STATE_CACHE_TTL_SECONDS=2
AGENT_MAX_STEPS=25

# Security (production)
BROWSER_BLOCK_LOCALHOST=true
BROWSER_ALLOW_JAVASCRIPT=true
BROWSER_MAX_SCRIPT_LENGTH=5000
# Comma-separated host allowlist (empty = allow any http/https except blocked)
# BROWSER_ALLOWED_HOSTS=google.com,example.com

# Audit log (~/Downloads/browser-mcp/audit.jsonl)
BROWSER_AUDIT_ENABLED=true
BROWSER_DOWNLOADS_PATH=~/Downloads/browser-mcp
BROWSER_NAVIGATE_RETRIES=1
